rules_version = '2';
// Atualizado 2026-04-17 — settings legível por todos autenticados
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["sacerdote", "tecnico"];
    }

    function isConselho() {
      return isAdmin() ||
        (isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "conselho");
    }

    function isMidias() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "midias";
    }

    // Usuários: cada um lê/escreve o próprio perfil
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isAdmin();
      allow read: if isConselho();
      allow read: if isMidias();
    }

    // Eventos: qualquer autenticado lê, admin escreve
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Cursos: qualquer autenticado lê, admin escreve
    match /courses/{courseId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Notificações
    // - usuário lê e atualiza (marcar como lida) as próprias
    // - conselho/admin/midias podem criar novas (para qualquer destinatário)
    // - conselho/admin podem deletar
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow read: if isConselho();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isConselho() || isMidias();
      allow delete: if isConselho();
    }

    // Config do sistema: todos leem, admin (sacerdote+tecnico) escreve
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Settings: todos autenticados leem (calendário ose, orixás, etc.), admin escreve
    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Integrações (API keys sensíveis): só tecnico lê/escreve
    match /settings/integrations {
      allow read, write: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "tecnico";
    }

    // Biblioteca: todos autenticados leem (filtragem por access é no cliente); admin escreve
    match /library/{itemId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Rituais (consultas e obrigações): conselho/sacerdote/tecnico
    match /rituals/{ritualId} {
      allow read, write: if isConselho();
    }

    // Grupos dinâmicos: conselho+ gerencia
    match /groups/{groupId} {
      allow read, write: if isConselho();

      // Subcoleção de dispatches (histórico de notificações enviadas ao grupo)
      match /dispatches/{dispatchId} {
        allow read, write: if isConselho();
      }
    }
  }
}
