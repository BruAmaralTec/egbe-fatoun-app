# ========================================
# Ẹgbẹ́ Fátọ́ún - API Payments
# ========================================

# Ambiente: "sandbox" ou "production"
ASAAS_ENV=sandbox

# Chave API do Asaas
# Sandbox: https://sandbox.asaas.com > Integrações > Gerar nova Chave de API
# Produção: https://www.asaas.com > Integrações > Gerar nova Chave de API
ASAAS_API_KEY=sua_chave_api_aqui

# Token secreto para validar webhooks do Asaas
ASAAS_WEBHOOK_TOKEN=um_token_secreto_qualquer

# Firebase
# Caminho para o arquivo de credenciais do Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=seu-projeto-firebase

# Servidor
PORT=8080
NODE_ENV=development

# CORS - domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://seu-dominio.vercel.app
